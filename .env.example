# ========================================
# Flame Core Frontend Environment Variables
# ========================================
#
# Copy this to:
# - .env.local (for local development)
# - .env.production (for production build)
#

# ─── Build Environment ──────────────────────────
NODE_ENV=development
MODE=development

# ─── Domain Configuration ───────────────────────
# Development (local machine)
VITE_MAIN_DOMAIN=http://localhost:5173
VITE_HOSTING_DOMAIN=http://localhost:5173
VITE_HOSTING_PATH=/hosting

# Production (your domains)
# VITE_MAIN_DOMAIN=https://flamecoretechltd.com
# VITE_HOSTING_DOMAIN=https://hosting.flamecoretechltd.com
# VITE_HOSTING_PATH=/hosting

# ─── Backend API URL ────────────────────────────
# This is where the Fastify backend is running
# Development (local)
VITE_API_URL=http://localhost:3001

# Production
# VITE_API_URL=https://api.flamecoretechltd.com

# ─── Debugging & Logging ────────────────────────
VITE_DEBUG=false
VITE_LOG_LEVEL=info

# ─── External Services (Optional) ───────────────
# Sentry error tracking (optional)
# VITE_SENTRY_DSN=https://xxx@sentry.io/project-id

# Analytics (optional)
# VITE_ANALYTICS_TOKEN=xxx

