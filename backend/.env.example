# ─────────────────────────────────────────────────────────────────────
# Flame Core — global-first PaaS configuration
#
# All settings are optional unless marked REQUIRED. The platform boots
# without any payment provider configured (for local dev). Add providers
# as you need them — the registry will detect and route automatically.
# ─────────────────────────────────────────────────────────────────────

# ── Database (REQUIRED) ──────────────────────────────────────────────
DATABASE_URL=postgresql://flame:password@localhost:5432/flamecore

# ── Queue / cache (REQUIRED) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API ──────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# ── Security (REQUIRED in production) ────────────────────────────────
JWT_SECRET=please-replace-with-openssl-rand-base64-32

# ── Default admin (only used on first boot) ──────────────────────────
ADMIN_EMAIL=admin@flamecore.app
ADMIN_PASSWORD=AdminPassword123!

# ── Deployment paths ─────────────────────────────────────────────────
DEPLOYMENT_BASE_PATH=/var/deployments/flame
NGINX_SITES_AVAILABLE=/etc/nginx/sites-available
NGINX_SITES_ENABLED=/etc/nginx/sites-enabled

# ─────────────────────────────────────────────────────────────────────
# Source providers
# ─────────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=

# Google OAuth
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {API_BASE_URL}/api/v1/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# ─── Frontend URL (for OAuth redirects back to the dashboard) ────────
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:3001

# ─────────────────────────────────────────────────────────────────────
# Payment providers — modular. Set whichever you use; the rest are skipped.
# ─────────────────────────────────────────────────────────────────────

# Stripe (USD, GBP, EUR, ZAR)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Paystack (NGN, GHS, KES, ZAR, USD)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Flutterwave (NGN, GHS, KES, ZAR, USD, GBP, EUR)
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_HASH=

# PayPal (USD, GBP, EUR — global fallback)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# ─────────────────────────────────────────────────────────────────────
# FX provider (for refreshing currency rates)
# Options: openexchangerates | frankfurter | manual
# ─────────────────────────────────────────────────────────────────────
FX_PROVIDER=manual
OPENEXCHANGERATES_APP_ID=

# ─────────────────────────────────────────────────────────────────────
# Multi-region (single-VPS today; ready for tomorrow)
# Set REGION_CODE to mark which region this API node serves.
# In a multi-VPS setup, each region runs its own node + worker.
# ─────────────────────────────────────────────────────────────────────
REGION_CODE=los1
INTERNAL_API_TOKEN=

# ── Object storage (for full deployment logs / build artifacts) ──────
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=debug
