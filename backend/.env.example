# ─────────────────────────────────────────────────────────────────────
# Flame Core — Global Hosting Platform (Production Configuration)
#
# For PRODUCTION deployment, all REQUIRED fields must be set.
# Development defaults are NOT suitable for production.
# ─────────────────────────────────────────────────────────────────────

# ── Environment ──────────────────────────────────────────────────────
NODE_ENV=production

# ── Database (REQUIRED) ──────────────────────────────────────────────
# Format: postgresql://user:password@host:port/dbname
# Use managed PostgreSQL (AWS RDS, Heroku Postgres, DigitalOcean) in production
DATABASE_URL=postgresql://user:password@prod-db.example.com:5432/flamecore_prod

# ── Queue / Cache (REQUIRED) ─────────────────────────────────────────
# Use managed Redis (AWS ElastiCache, Heroku Redis, DigitalOcean) in production
REDIS_URL=redis://prod-redis.example.com:6379

# ── API Configuration ────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0

# ── Security (REQUIRED in production) ────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=YOUR_PRODUCTION_SECRET_HERE_CHANGE_THIS

# ── CORS Origins (REQUIRED in production) ────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=https://flamecoretechltd.com,https://www.flamecoretechltd.com,https://console.flamecoretechltd.com

# ── Admin Account (only used on first boot) ─────────────────────────
# Change these in production and store securely
ADMIN_EMAIL=your-admin@example.com
ADMIN_PASSWORD=generate_strong_password_here

# ── Deployment paths (host machine) ──────────────────────────────────
DEPLOYMENT_BASE_PATH=/var/deployments/flame
NGINX_SITES_AVAILABLE=/etc/nginx/sites-available
NGINX_SITES_ENABLED=/etc/nginx/sites-enabled

# ─────────────────────────────────────────────────────────────────────
# Frontend & OAuth URLs (REQUIRED in production)
# ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://flamecoretechltd.com
API_BASE_URL=https://api.flamecoretechltd.com

# ─────────────────────────────────────────────────────────────────────
# Source Providers (GitHub, Google, GitLab)
# ─────────────────────────────────────────────────────────────────────

# GitHub OAuth — Create app at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_APP_PRIVATE_KEY=

# Google OAuth — Create at: https://console.cloud.google.com/apis/credentials
# Redirect URI: https://api.flamecoretechltd.com/api/v1/oauth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitLab OAuth (optional)
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────
# Payment Providers — Global First
# Only configure the providers you'll use. The system auto-detects enabled ones.
# ─────────────────────────────────────────────────────────────────────

# Stripe (USD, GBP, EUR, ZAR, etc.) — Global
STRIPE_SECRET_KEY=sk_live_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Paystack (NGN, GHS, KES, ZAR, USD) — Africa-focused
PAYSTACK_SECRET_KEY=sk_live_your_paystack_key_here
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_key_here

# Flutterwave (NGN, GHS, KES, ZAR, USD, GBP, EUR) — Africa-focused
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_here
FLUTTERWAVE_PUBLIC_KEY=your_flutterwave_public_here
FLUTTERWAVE_SECRET_HASH=your_hash_here

# PayPal (USD, GBP, EUR) — Global fallback
# Live mode is enabled by default in production
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=live

# ─────────────────────────────────────────────────────────────────────
# Email / SMTP (REQUIRED for email verification & notifications)
# ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key_here
SMTP_FROM_EMAIL=noreply@flamecoretechltd.com

# ─────────────────────────────────────────────────────────────────────
# Currency / FX (optional)
# ─────────────────────────────────────────────────────────────────────
FX_PROVIDER=manual
OPENEXCHANGERATES_APP_ID=

# ─────────────────────────────────────────────────────────────────────
# Multi-region (single-VPS today; ready for tomorrow)
# Set REGION_CODE to mark which region this API node serves.
# In a multi-VPS setup, each region runs its own node + worker.
# ─────────────────────────────────────────────────────────────────────
REGION_CODE=los1
INTERNAL_API_TOKEN=

# ── Object storage (for full deployment logs / build artifacts) ──────
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=debug
