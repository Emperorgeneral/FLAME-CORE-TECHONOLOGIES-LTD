NODE_ENV=production
PORT=5000
# Comma-separated allowlist of frontend origins
FRONTEND_URLS=https://flamecoretechltd.com,https://www.flamecoretechltd.com
# Remote PostgreSQL (no local sqlite file)
DATABASE_URL="postgresql://flame_user:replace_password@db.example.com:5432/flamecore_prod?schema=public&sslmode=require"
JWT_SECRET=replace_with_64_plus_char_random_secret
JWT_EXPIRES_IN=7d
JWT_ISSUER=flamecore-backend
JWT_AUDIENCE=flamecore-clients
TRUST_PROXY=1
STRIPE_SECRET_KEY=replace_with_stripe_secret_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret
GOOGLE_CLIENT_ID=replace_with_google_oauth_client_id.apps.googleusercontent.com
# Admin panel anonymous key(s). You can rotate by comma-separating multiple keys.
ADMIN_SECRET_KEY=replace_with_strong_admin_key_min_32_chars
